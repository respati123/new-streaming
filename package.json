{
  "name": "streaming-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "be",
    "fe"
  ],
  "scripts": {
    "dev": "bun run --cwd be dev & bun run --cwd fe dev",
    "dev:be": "bun run --cwd be dev",
    "dev:fe": "bun run --cwd fe dev",
    "install:all": "bun install",
    "db:generate": "bun run --cwd be db:generate",
    "db:push": "bun run --cwd be db:push",
    "db:studio": "bun run --cwd be db:studio",
    "build:fe": "bun run --cwd fe build",
    "start:be": "bun run --cwd be start"
  }
}
