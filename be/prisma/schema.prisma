datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id              Int        @id @default(autoincrement())
  youtubeId       String     @unique @map("youtube_id")
  name            String
  bio             String?    // Informasi permanen/fakta tentang user ini
  profileImageUrl String?    @map("profile_image_url")
  points          Int        @default(0)
  lifetimePoints  Int        @default(0) @map("lifetime_points")
  lastSeen        DateTime   @map("last_seen")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")

  messages        Message[]
  donations       Donation[]

  @@map("users")
}

model Stream {
  id             Int       @id @default(autoincrement())
  youtubeVideoId String    @unique @map("youtube_video_id")
  title          String
  description    String?
  status         String
  startedAt      DateTime  @map("started_at")
  endedAt        DateTime? @map("ended_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  messages       Message[]

  @@map("streams")
}

model Donation {
  id            Int       @id @default(autoincrement())
  donatorName   String    @map("donator_name")
  donatorEmail  String?   @map("donator_email")
  amountRaw     Int       @map("amount_raw")
  message       String?
  externalId    String?   @unique @map("external_id")
  type          String
  donationType  String    @default("tts") @map("donation_type")
  isShown       Boolean   @default(false) @map("is_shown")
  userId        Int?      @map("user_id")
  aiReply       String?   @map("ai_reply")
  createdAt     DateTime  @default(now()) @map("created_at")

  user          User?     @relation(fields: [userId], references: [id])

  @@map("donations")
}

model Message {
  id          Int      @id @default(autoincrement())
  content     String
  streamId    Int      @map("stream_id")
  userId      Int      @map("user_id")
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  stream      Stream   @relation(fields: [streamId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("messages")
}

model Tier {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  badge     String
  color     String
  minPoints Int      @map("min_points")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tiers")
}